# Порт Express backend
PORT=3001

# Адрес 1С. В документе endpoint указан без протокола, поэтому здесь добавлен http://
ONE_C_URL=http://10.205.100.22/yniv/hs/exchange_sayt/get_applicants_statistics

# В присланном тестовом proxy использовался пользователь http_user_reserv.
# В документе указан http_user_mlgu. Оставьте фактического рабочего пользователя.
ONE_C_USER=http_user_reserv
ONE_C_PASSWORD=PUT_PASSWORD_HERE

# В рабочем proxy запрос к 1С выполнялся методом GET с JSON body { period }.
ONE_C_METHOD=GET
ONE_C_TIMEOUT=30000

# true — показывать демо-данные без подключения к 1С.
# Если .env не создан или не заполнен пароль, сервер сам включит mock-режим.
ONE_C_USE_MOCK=false

# Для разработки можно оставить * или не задавать.
CORS_ORIGIN=*
