{
  "name": "dashboard-1c-university",
  "version": "1.0.14",
  "private": true,
  "type": "module",
  "description": "React + Express dashboard for 1C applicants statistics",
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "test": "node --test",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cors": "^2.8.5",
    "date-fns": "3.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-datepicker": "^7.6.0",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.9",
    "vite": "^8.0.16"
  }
}
